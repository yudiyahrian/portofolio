# ─────────────────────────────────────────────────────────────────────────────
# Resend — https://resend.com
# Free tier: 3,000 emails/month, 100/day
#
# Steps:
#  1. Sign up at https://resend.com
#  2. Go to API Keys → Create API Key (name it "Portfolio")
#  3. Paste the key below
#  4. (Optional) Add & verify your domain at Domains → Add Domain
#     Then change FROM_EMAIL to contact@yourdomain.com
# ─────────────────────────────────────────────────────────────────────────────

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The "from" address for outgoing emails.
# BEFORE domain verification → use the Resend sandbox address:
FROM_EMAIL=onboarding@resend.dev
# AFTER verifying your domain → change to your own:
# FROM_EMAIL=contact@yudiyaahrian.dev
